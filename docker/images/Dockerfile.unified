# SimHPC Unified Dockerfile - v2.7.2 (uv + Supervisor)
FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    APP_HOME=/app \
    PYTHONPATH=/app \
    HF_HOME=/workspace/huggingface \
    VLLM_CACHE=/workspace/vllm_cache

WORKDIR $APP_HOME

# Install system dependencies and uv
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    tini \
    supervisor \
    psmisc \
    && curl -LsSf https://astral.sh/uv/install.sh | sh \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/root/.local/bin/:$PATH"

# Install Python dependencies using uv
COPY pyproject.toml uv.lock ./
RUN uv pip install --system --no-cache .[worker,gpu]

# Copy application code
COPY run_api.py ./
COPY app/ ./app/

# Create cache directories
RUN mkdir -p /workspace/huggingface /workspace/vllm_cache

# Copy supervisord and wait scripts
COPY docker/supervisor/supervisord.conf /etc/supervisor/conf.d/supervisord.conf
COPY docker/scripts/ ./docker/scripts/
RUN chmod +x docker/scripts/*.sh

# RunPod expects API on 8888 for routing
EXPOSE 8888

ENTRYPOINT ["/usr/bin/tini", "--"]
# Kill any existing Jupyter/RunPod services holding the port 8888, then start supervisor
CMD ["sh", "-c", "fuser -k 8888/tcp || true && /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf"]
