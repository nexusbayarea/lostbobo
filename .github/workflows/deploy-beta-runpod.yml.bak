name: Deploy Beta to RunPod

on:
  push:
    branches: [ "main" ]

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_LOGIN }}
          password: ${{ secrets.DOCKER_PW_TOKEN }}

      - name: Build and push worker image
        uses: docker/build-push-action@v6
        with:
          context: .
          file: ./docker/images/Dockerfile.unified
          push: true
          tags: |
            simhpcworker/simhpc-unified:latest
            simhpcworker/simhpc-unified:${{ github.run_id }}

      - name: Reset RunPod Pod (resilient)
        env:
          RUNPOD_API_KEY: ${{ secrets.RUNPOD_API_KEY }}
          RUNPOD_ID: ${{ secrets.RUNPOD_ID }}
        run: |
          echo "Targeting Pod: $RUNPOD_ID"
          
          # 1. ATTEMPT PRIMARY METHOD: podReset
          echo "--- Attempting podReset (Primary) ---"
          RESPONSE=$(curl -s -X POST "https://api.runpod.io/graphql" \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer $RUNPOD_API_KEY" \
            -H "x-apollo-operation-name: podReset" \
            -d "{\"query\": \"mutation { podReset(input: { podId: \\\"$RUNPOD_ID\\\" }) { id desiredStatus } }\"}")
          
          echo "API Response: $RESPONSE"

          if echo "$RESPONSE" | grep -qE '"errors"|"error"' || [[ -z "$RESPONSE" ]]; then
            echo "podReset failed. Triggering fallback cycle (Stop -> Resume)..."
            
            # 2. FALLBACK STAGE 1: STOP
            echo "--- Fallback Stage 1: Stopping Pod ---"
            STOP_RESP=$(curl -s -X POST "https://api.runpod.io/graphql" \
              -H "Content-Type: application/json" \
              -H "Authorization: Bearer $RUNPOD_API_KEY" \
              -d "{\"query\": \"mutation { podStop(input: { podId: \\\"$RUNPOD_ID\\\" }) { id } }\"}")
            echo "Stop Response: $STOP_RESP"
            
            echo "Waiting 20 seconds for GPU release..."
            sleep 20
            
            # 3. FALLBACK STAGE 2: RESUME
            echo "--- Fallback Stage 2: Resuming Pod ---"
            RESUME_RESP=$(curl -s -X POST "https://api.runpod.io/graphql" \
              -H "Content-Type: application/json" \
              -H "Authorization: Bearer $RUNPOD_API_KEY" \
              -d "{\"query\": \"mutation { podResume(input: { podId: \\\"$RUNPOD_ID\\\", gpuCount: 1 }) { id } }\"}")
            echo "Resume Response: $RESUME_RESP"

            if echo "$RESUME_RESP" | grep -q "\"errors\""; then
              echo "CRITICAL ERROR: Both Reset and Resume failed."
              exit 1
            fi
            echo "Pod successfully cycled via Fallback"
          else
            echo "Pod successfully reset on the first try"
          fi