# --- MERCURY / AI STACK ---
# For Alpha (Mercury 2)
MERCURY_API_KEY=your_mercury_key_here

# For Beta (Preparation for Qwen/Mathstral/Rnj-1)
# If using a provider like OpenRouter or RunPod
BETA_INFERENCE_URL=https://api.runpod.ai/v2/...
BETA_INFERENCE_KEY=rpa_...

# --- DATABASE & STORAGE ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...
# Used to verify the JWT from the frontend
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_settings

# --- REDIS (Simulation Queue) ---
REDIS_URL=redis://localhost:6379

# --- STRIPE (Billing Verification) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
