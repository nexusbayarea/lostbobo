name: Debug Secrets

on: workflow_dispatch

jobs:
  debug:
    runs-on: ubuntu-latest
    steps:
      - name: List all secrets
        run: |
          echo "=== Repository Secrets ==="
          echo "DOCKER_LOGIN: ${{ secrets.DOCKER_LOGIN != '' }}"
          echo "DOCKER_PW_TOKEN: ${{ secrets.DOCKER_PW_TOKEN != '' }}"
          echo "DOCKER_USERNAME: ${{ secrets.DOCKER_USERNAME != '' }}"
          echo "DOCKER_PASSWORD: ${{ secrets.DOCKER_PASSWORD != '' }}"
          echo "DOCKER_HUB_USERNAME: ${{ secrets.DOCKER_HUB_USERNAME != '' }}"
          echo "DOCKER_HUB_TOKEN: ${{ secrets.DOCKER_HUB_TOKEN != '' }}"
          
          echo ""
          echo "=== Environment Secrets ==="
          echo "DOCKER_LOGIN: ${{ env.DOCKER_LOGIN != '' }}"
          echo "DOCKER_PW_TOKEN: ${{ env.DOCKER_PW_TOKEN != '' }}"
          
          echo ""
          echo "=== All secrets starting with DOCKER ==="
          echo "Looking for secrets that contain 'DOCKER' in the name..."