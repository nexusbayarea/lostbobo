{
  "buildCommand": "cd apps/frontend && npm install && npm run build",
  "installCommand": "cd apps/frontend && npm install",
  "outputDirectory": "apps/frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/v1/internal/force-flush",
      "schedule": "* * * * *"
    }
  ]
}