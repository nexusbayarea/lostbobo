# --- SimHPC v2.5.0 Environment Template ---
# Use 'infisical secrets set [KEY]=[VALUE]' to populate these.
# This file contains placeholders for all required environment variables.
# DO NOT COMMIT ACTUAL VALUES TO THIS FILE.

# Core Auth & Security
SIMHPC_API_KEY=placeholder_set_in_infisical
JWT_ALGORITHM=HS256
ADMIN_SECRET=placeholder_set_in_infisical

# Infrastructure (GCP & RunPod)
GCP_PROJECT_ID=placeholder_set_in_infisical
RUNPOD_API_KEY=placeholder_set_in_infisical
RUNPOD_POD_ID=placeholder_set_in_infisical
RUNPOD_SSH_KEY=placeholder_set_in_infisical
# Frontend (Vite build-time injection — required for browser)
VITE_SUPABASE_URL=placeholder_set_in_infisical
VITE_SUPABASE_ANON_KEY=placeholder_set_in_infisical
VITE_API_URL=http://localhost:8000

# Backend (runtime injection)
SUPABASE_SERVICE_ROLE_KEY=placeholder_set_in_infisical

# AI Guidance (Mercury)
MERCURY_API_KEY=placeholder_set_in_infisical
MERCURY_API_URL=https://api.inceptionlabs.ai/v1/chat/completions
MERCURY_MODEL_ID=mercury-2

# Services
REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=http://localhost:3000
