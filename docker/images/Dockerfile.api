# SimHPC API - v2.7.4
FROM python:3.11-slim

WORKDIR /app

RUN pip install uv

# Copy application code
COPY run_api.py ./
COPY app/ ./app/

# Setup Non-Root User
RUN useradd -m simuser && chown -R simuser:simuser /app
USER simuser

EXPOSE 8080

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python3", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080"]
