# SimHPC Unified Dockerfile - v2.7.0 (Supervisor Driven)
FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    APP_HOME=/app \
    PYTHONPATH=/app \
    HF_HOME=/workspace/huggingface \
    VLLM_CACHE=/workspace/vllm_cache

WORKDIR $APP_HOME

# System dependencies (including psmisc for fuser)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    tini \
    supervisor \
    psmisc \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY run_api.py ./
COPY app/ ./app/

# Create cache directories
RUN mkdir -p /workspace/huggingface /workspace/vllm_cache

# Copy supervisord configuration
COPY docker/supervisor/supervisord.conf /etc/supervisor/conf.d/supervisord.conf        

# RunPod expects API on 8888 for routing
EXPOSE 8888

ENTRYPOINT ["/usr/bin/tini", "--"]
# Kill any existing Jupyter/RunPod services holding the port 8888, then start supervisor
CMD ["sh", "-c", "fuser -k 8888/tcp || true && /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf"]
