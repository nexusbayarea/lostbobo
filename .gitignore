# ==============================================================================
# SimHPC .gitignore
.imc-cache
 — PUBLIC REPO (FRONTEND ONLY)
# ==============================================================================

# Backend system - BLOCKED
app/
worker/
ci/
autoscaler/
tools/
infra/
docker/
# Allow frontend scripts
!frontend/scripts/
scripts/
runtime/
packages/

# Docker
# Allow Docker build files
!docker/

# Python - no backend present
*.py
__pycache__/
.venv/
venv/
ENV/
.pytest_cache/
.ruff_cache/
*.egg-info/

# Node / Frontend
node_modules/
dist/
build/
.vercel/
.next/
*.tsbuildinfo

# Secrets
.env
.env.*
*.pem
*.key

# IDE
.vscode/
.idea/
.DS_Store

# Data
data/
logs/
*.log

# Legacy / Internal
skills/
legacy_archive/
skills/
*.md
# Exclude internal docs
READ ME_DO NOT PUSH/
!README.md

# Build artifacts
simhpc.egg-info/
.vercel

.gemini/
gha-creds-*.json

.gemini/
gha-creds-*.json

# PROGRESS.md
progress.md

